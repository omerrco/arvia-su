---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  tone?: "default" | "light";
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  tone = "default",
  align = "left",
} = Astro.props;

const tones = {
  default: {
    eyebrow: "text-brand-600",
    title: "text-brand-900",
    description: "text-muted",
  },
  light: {
    eyebrow: "text-brand-300",
    title: "text-white",
    description: "text-white/75",
  },
};

const alignment = align === "center" ? "mx-auto text-center" : "";
---

<div class={`max-w-3xl ${alignment}`}>
  {
    eyebrow && (
      <p
        class={`${tones[tone].eyebrow} mb-3 text-sm font-semibold tracking-[0.18em] uppercase`}
      >
        {eyebrow}
      </p>
    )
  }
  <h2
    class={`${tones[tone].title} font-display text text-3xl font-medium tracking-tight md:text-4xl`}
  >
    {title}
  </h2>
  {
    description && (
      <p
        class={`${tones[tone].description} mt-4 text-base leading-7 md:text-lg`}
      >
        {description}
      </p>
    )
  }
</div>
