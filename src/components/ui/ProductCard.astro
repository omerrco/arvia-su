---
import { Image } from "astro:assets";
import type { Product } from "../../data/products";
import LinkButton from "./LinkButton.astro";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article
  class="hover:border-brand-200 group rounded-card flex flex-col overflow-hidden border border-slate-200 bg-white transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-900/5"
>
  <div class="aspect-3/2 overflow-hidden bg-slate-100">
    <Image
      src={product.image}
      alt={product.imageAlt}
      class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>

  <div class="flex flex-1 flex-col p-6">
    <p class="text-brand-700 text-xs font-semibold tracking-wider uppercase">
      {product.category}
    </p>

    <h3 class="font-display mt-2 text-xl font-bold text-slate-950">
      {product.title}
    </h3>

    <p class="text-muted mt-3 flex-1 leading-6">
      {product.summary}
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      {
        product.idealFor
          .slice(0, 2)
          .map((item) => (
            <span class="bg-brand-50 rounded-full px-2.5 py-1 text-xs font-medium text-slate-700">
              {item}
            </span>
          ))
      }
    </div>

    <div class="mt-6">
      <LinkButton href="" class="w-full"> Ürünü inceleyin </LinkButton>
    </div>
  </div>
</article>
